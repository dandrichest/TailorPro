@page "/"
@using Microsoft.EntityFrameworkCore
@using TailorPro.Data
@using TailorPro.Models
@inject ApplicationDbContext Db
@rendermode InteractiveServer

<PageTitle>Dashboard — TailorPro</PageTitle>

<h3 class="mb-4">Dashboard</h3>

@if (!loaded)
{
    <p>Loading...</p>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Customers</h5>
                    <p class="card-text fs-2 fw-bold">@totalCustomers</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Pending Orders</h5>
                    <p class="card-text fs-2 fw-bold">@pendingOrders</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">In Progress</h5>
                    <p class="card-text fs-2 fw-bold">@inProgressOrders</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Completed</h5>
                    <p class="card-text fs-2 fw-bold">@completedOrders</p>
                </div>
            </div>
        </div>
    </div>

    <h5 class="mb-3">Recent Orders</h5>
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Customer</th>
                <th>Description</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in recentOrders)
            {
                <tr>
                    <td>@o.Customer.FullName</td>
                    <td>@o.Description</td>
                    <td>
                        <span class="badge @BadgeClass(o.Status)">@o.Status</span>
                    </td>
                    <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool loaded = false;
    private int totalCustomers, pendingOrders, inProgressOrders, completedOrders;
    private List<Order> recentOrders = new();

    protected override async Task OnInitializedAsync()
    {
        totalCustomers   = await Db.Customers.CountAsync();
        pendingOrders    = await Db.Orders.CountAsync(o => o.Status == OrderStatus.Pending);
        inProgressOrders = await Db.Orders.CountAsync(o => o.Status == OrderStatus.InProgress);
        completedOrders  = await Db.Orders.CountAsync(o => o.Status == OrderStatus.Completed);
        recentOrders     = await Db.Orders
                                   .Include(o => o.Customer)
                                   .OrderByDescending(o => o.OrderDate)
                                   .Take(5)
                                   .ToListAsync();
        loaded = true;
    }

    private string BadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending    => "bg-warning text-dark",
        OrderStatus.InProgress => "bg-info text-dark",
        OrderStatus.Completed  => "bg-success",
        OrderStatus.Delivered  => "bg-secondary",
        _                      => "bg-light text-dark"
    };
}