@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using TailorPro.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Log in – TailorPro</PageTitle>

<div class="login-wrapper">
    <div class="login-card">

        <!-- Brand Header -->
        <div class="login-brand">
            <svg width="36" height="36" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 8 L16 4 L26 8 L26 18 Q26 26 16 30 Q6 26 6 18 Z" fill="#2D5016" />
                <path d="M12 16 L15 19 L21 13" stroke="#A8D45A" stroke-width="2.5" stroke-linecap="round"
                      stroke-linejoin="round" fill="none" />
            </svg>
            <span class="brand-name"><strong>Tailor</strong><span class="brand-accent">Pro</span></span>
        </div>

        <h1 class="login-title">Welcome back</h1>
        <p class="login-subtitle">Sign in to your account to continue.</p>

        <StatusMessage Message="@errorMessage" />

        <EditForm EditContext="editContext" method="post" OnSubmit="LoginUser" FormName="login">
            <DataAnnotationsValidator />
            <ValidationSummary class="tp-alert" role="alert" />

            <div class="tp-field">
                <label for="Input.Email">Email address</label>
                <InputText @bind-Value="Input.Email" id="Input.Email" class="tp-input" autocomplete="username webauthn"
                           aria-required="true" placeholder="name@example.com" />
                <ValidationMessage For="() => Input.Email" class="tp-error" />
            </div>

            <div class="tp-field">
                <label for="Input.Password">Password</label>
                <InputText type="password" @bind-Value="Input.Password" id="Input.Password" class="tp-input"
                           autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                <ValidationMessage For="() => Input.Password" class="tp-error" />
            </div>

            <div class="tp-remember">
                <label class="tp-checkbox-label">
                    <InputCheckbox @bind-Value="Input.RememberMe" class="tp-checkbox" />
                    Remember me
                </label>
                <a href="Account/ForgotPassword" class="tp-link-muted">Forgot password?</a>
            </div>

            <button type="submit" class="tp-btn-primary w-100">Log in</button>

            <div class="tp-divider"><span>or</span></div>

            <PasskeySubmit Operation="PasskeyOperation.Request" Name="Input.Passkey" EmailName="Input.Email"
                           class="tp-btn-outline w-100">
                Log in with a passkey
            </PasskeySubmit>
        </EditForm>

        <div class="login-footer">
            Don't have an account?
            <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))"
               class="tp-link">
                Create one
            </a>
        </div>

        <div class="login-footer mt-2">
            <a href="Account/ResendEmailConfirmation" class="tp-link-muted">Resend email confirmation</a>
        </div>

        <div class="login-external">
            <p class="external-label">Or continue with</p>
            <ExternalLoginPicker />
        </div>

    </div>
</div>

<style>
    .login-wrapper {
        min-height: calc(100vh - 65px);
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8f9f5;
        padding: 2rem 1rem;
    }

    .login-card {
        background: #ffffff;
        border: 1px solid #eef0eb;
        border-radius: 16px;
        padding: 2.5rem 2.25rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 4px 24px rgba(45, 80, 22, 0.06);
    }

    .login-brand {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-bottom: 1.5rem;
    }

    .brand-name {
        font-size: 1.3rem;
        color: #1a2410;
        letter-spacing: -0.02em;
    }

    .brand-accent {
        color: #4a8a1e;
    }

    .login-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1a2410;
        text-align: center;
        margin-bottom: 0.35rem;
        letter-spacing: -0.02em;
    }

    .login-subtitle {
        font-size: 0.88rem;
        color: #888;
        text-align: center;
        margin-bottom: 1.75rem;
    }

    .tp-alert {
        background: #fdf0f1;
        border: 1px solid #f5c0c4;
        color: #8B2635;
        border-radius: 8px;
        padding: 0.65rem 0.9rem;
        font-size: 0.85rem;
        margin-bottom: 1rem;
    }

    .tp-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
        margin-bottom: 1rem;
    }

    .tp-field label {
        font-size: 0.83rem;
        font-weight: 600;
        color: #3d3d3d;
    }

    .tp-input {
        width: 100%;
        padding: 0.65rem 0.9rem;
        border: 1.5px solid #dde5d0;
        border-radius: 8px;
        font-size: 0.92rem;
        color: #1a2410;
        background: #fff;
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
    }

    .tp-input:focus {
        border-color: #2D5016;
        box-shadow: 0 0 0 3px rgba(45, 80, 22, 0.1);
    }

    .tp-input::placeholder {
        color: #bbb;
    }

    .tp-error {
        font-size: 0.78rem;
        color: #8B2635;
    }

    .tp-remember {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .tp-checkbox-label {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 0.85rem;
        color: #555;
        cursor: pointer;
    }

    .tp-checkbox {
        width: 15px;
        height: 15px;
        accent-color: #2D5016;
        cursor: pointer;
    }

    .tp-btn-primary {
        display: block;
        width: 100%;
        background: #2D5016;
        color: #ffffff;
        border: none;
        padding: 0.7rem 1rem;
        border-radius: 8px;
        font-size: 0.92rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s;
        text-align: center;
    }

    .tp-btn-primary:hover {
        background: #3d6b1e;
    }

    .tp-btn-outline {
        display: block;
        width: 100%;
        background: transparent;
        color: #2D5016;
        border: 1.5px solid #2D5016;
        padding: 0.65rem 1rem;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s;
        text-align: center;
        text-decoration: none;
    }

    .tp-btn-outline:hover {
        background: #f0f5e8;
    }

    .tp-divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 1.1rem 0;
        color: #bbb;
        font-size: 0.78rem;
        gap: 10px;
    }

    .tp-divider::before,
    .tp-divider::after {
        content: '';
        flex: 1;
        border-top: 1px solid #eef0eb;
    }

    .tp-link {
        color: #2D5016;
        font-weight: 600;
        text-decoration: none;
    }

    .tp-link:hover {
        text-decoration: underline;
    }

    .tp-link-muted {
        color: #999;
        font-size: 0.83rem;
        text-decoration: none;
    }

    .tp-link-muted:hover {
        color: #2D5016;
        text-decoration: underline;
    }

    .login-footer {
        text-align: center;
        font-size: 0.85rem;
        color: #888;
        margin-top: 1.25rem;
    }

    .login-external {
        margin-top: 1.5rem;
        border-top: 1px solid #eef0eb;
        padding-top: 1.25rem;
    }

    .external-label {
        text-align: center;
        font-size: 0.82rem;
        color: #aaa;
        margin-bottom: 0.75rem;
    }
</style>

@code {
    private string? errorMessage;
    private EditContext editContext = default!;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();
        editContext = new EditContext(Input);

        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

    public async Task LoginUser()
    {
        if (!string.IsNullOrEmpty(Input.Passkey?.Error))
        {
            errorMessage = $"Error: {Input.Passkey.Error}";
            return;
        }

        SignInResult result;
        if (!string.IsNullOrEmpty(Input.Passkey?.CredentialJson))
        {
            result = await SignInManager.PasskeySignInAsync(Input.Passkey.CredentialJson);
        }
        else
        {
            if (!editContext.Validate())
            {
                return;
            }
            result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure:
false);
        }

        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            errorMessage = "Error: Invalid login attempt.";
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }

        public PasskeyInputModel? Passkey { get; set; }
    }
}
